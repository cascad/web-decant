# Keep UNIX shell scripts LF even when committed from Windows
# (a CRLF here would break the shebang on macOS/Linux).
*.sh        text eol=lf
install.sh  text eol=lf
decant      text eol=lf

# Keep Windows scripts CRLF
*.ps1       text eol=crlf
*.cmd       text eol=crlf
*.bat       text eol=crlf

# Normalize the rest
*.py        text
*.md        text
